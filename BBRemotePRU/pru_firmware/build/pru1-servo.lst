      69  ; P8_42 gpio2[11]-> bit11 output_MC_D config-pin P8_42 gpio
      70
      71  ; P8_39 gpio2[12]-> bit12 output_MD_E config-pin P8_39 gpio
      72  ; P8_40 gpio2[13]-> bit13 output_MD_D config-pin P8_40 gpio
      73
      74  ; Step period (medio ciclo de la senial)
      75  .asg (1<<14), GPIO2_14_MA_S                           ; P8_37 gpio2[14] output_MA_S no hace falta ha
      76  .asg (1<<15), GPIO2_15_MB_S                           ; P8_38 gpio2[15] output_MB_S
      77  .asg (1<<16), GPIO2_16_MC_S                           ; P8_36 gpio2[16] output_MC_S
      78  .asg (1<<17), GPIO2_17_MD_S                           ; P8_34 gpio2[17] output_MD_S
      79
      80  .asg 32, PRU0_R31_VEC_VALID                           ; allows notification of program completion
      81  .asg 3,  PRU_EVTOUT_0                                 ; the event number that is sent back
      82
      83  .clink
      84  .global start
