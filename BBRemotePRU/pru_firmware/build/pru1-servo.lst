       9;
      10; PRU definitions
      11; memory
      12  .asg 0x00000000, RAM0_ADDR                            ; local addr ram0. In linux space addr is 0x4a
      13  .asg 0x00002000, RAM1_ADDR                            ; local addr ram1. In linux space addr is 0x4a
      14  .asg 0x00010000, SHARED_ADDR                          ; local addr shared. In linux space addr is 0x
      15  .asg 0x00, SHD_0                                      ; shared[0] flags linux
      16  .asg 0x04, SHD_1                                      ; shared[1] gpio_read bit4-> flag | bit0-bit3-
      17  .asg 0x08, SHD_2                                      ; shared[2] gpio_write bit8-> flag write compl
      18  .asg 0x0C, SHD_3                                      ; shared[3] motor bit12-> flag config complete
      19  .asg 0x10, SHD_4                                      ; shared[4] motor_A STEP_PERIOD_A
      20  .asg 0x14, SHD_5                                      ; shared[5] motor_B STEP_PERIOD_B
      21  .asg 0x18, SHD_6                                      ; shared[6] motor_C STEP_PERIOD_C
      22  .asg 0x1C, SHD_7                                      ; shared[7] motor_D STEP_PERIOD_D
      23  .asg 0x0a, SHARED_MEM_SIZE                            ; 10 en decimal
      24  .asg 0x04, OFFSET_MEM                                 ;
      25
      26; gpio bank
      27  .asg 0x44e07000, GPIO0                                ; GPIO Bank 0, See the AM335x TRM
      28  .asg 0x481ac000, GPIO2                                ; GPIO Bank 2
      29
      30  .asg 0x190, GPIO_CLRDATAOUT                           ; for clearing the GPIO registers
      31  .asg 0x194, GPIO_SETDATAOUT                           ; for setting the GPIO registers
      32  .asg 0x13C, GPIO_DATAOUT                              ; for read-write the GPIO registers
      33  .asg 0x138, GPIO_DATAIN                               ; for reading the GPIO registers
      34
      35  .asg 0x130, GPIO_CTRL                                 ; enable GPIO port
      36  .asg 0x00,  GPIO_CTRL_ENABLE                          ;
      37  .asg 0x134, GPIO_OE                                   ; set GPIO input - output
      38  .asg 0xFC3C003F, GPIO_OE_OUTPUT                       ; pines usados como salida bit6 a bit17 y bit2
      39  .asg 0xF0,  GPIO_OE_INPUT                             ; para todos lo pines usados como entrada bit8
      40
      41; gpio_read
      42  ; Pins
      43  ; P8_35 gpio0[8] -> bit8 input_0  no hace falta hacer: config-pin P8_35 gpio_pd
      44  ; P8_33 gpio0[9] -> bit9 input_1  no hace falta hacer: config-pin P8_33 gpio_pd
      45  ; P8_31 gpio0[10]-> bit10 input_2 no hace falta hacer: config-pin P8_31 gpio_pd
      46  ; P8_32 gpio0[11]-> bit11 input_3 no hace falta hacer: config-pin P8_32 gpio_pd
      47
      48; gpio_write
      49  .asg  (1<<22),  GPIO_OUT_BASE                         ;
      50  ; Pins
      51  ; P8_27 gpio2[22]-> bit22 output_0 no hace falta hacer: config-pin P8_27 gpio
      52  ; P8_29 gpio2[23]-> bit23 output_1 no hace falta hacer: config-pin P8_29 gpio
      53  ; P8_28 gpio2[24]-> bit24 output_2 no hace falta hacer: config-pin P8_28 gpio
      54  ; P8_30 gpio2[25]-> bit25 output_3 no hace falta hacer: config-pin P8_30 gpio
      55
