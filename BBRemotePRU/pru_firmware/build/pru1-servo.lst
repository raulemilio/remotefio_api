      60; gpio_read
      61  ; Pins
      62  ; P8_35 gpio0[8] -> bit8 input_0  no hace falta hacer: config-pin P8_35 gpio_pd
      63  ; P8_33 gpio0[9] -> bit9 input_1  no hace falta hacer: config-pin P8_33 gpio_pd
      64  ; P8_31 gpio0[10]-> bit10 input_2 no hace falta hacer: config-pin P8_31 gpio_pd
      65  ; P8_32 gpio0[11]-> bit11 input_3 no hace falta hacer: config-pin P8_32 gpio_pd
      66
      67  ; MOTOR_A hardware pins
      68  .asg 22, INPUT_MA_DISABLE                             ; P8_19 gpio0[22]-> bit22 input_MA_E set disab
      69  .asg 23, INPUT_MA_TD                                  ; P8_13 gpio0[23]-> bit23 input_MA_D set toogl
      70  ; MOTOR_B hardware pins
      71  .asg 26, INPUT_MB_DISABLE                             ; P8_14 gpio0[26]-> bit26 input_MB_E set disab
      72  .asg 27, INPUT_MB_TD                                  ; P8_17 gpio0[27]-> bit27 input_MB_D set toogl
      73  .asg 1, INPUT_GPIO_READ_ASC                           ; P8_18 gpio2[1]-> bit1 input gpio read send r
      74
      75; gpio_write
      76  .asg  (1<<22),  GPIO_OUT_BASE                         ;
      77  ; Pins
      78  ; P8_27 gpio2[22]-> bit22 output_0 no hace falta hacer: config-pin P8_27 gpio
      79  ; P8_29 gpio2[23]-> bit23 output_1 no hace falta hacer: config-pin P8_29 gpio
      80  ; P8_28 gpio2[24]-> bit24 output_2 no hace falta hacer: config-pin P8_28 gpio
      81  ; P8_30 gpio2[25]-> bit25 output_3 no hace falta hacer: config-pin P8_30 gpio
      82
      83; motor
      84  ; Enable-Direction
      85  .asg (1<<6), GPIO_MOTOR_ENA_BASE                      ;
      86  .asg (1<<7), GPIO_MOTOR_DIR_BASE                      ;
      87
      88  ; Pins
      89  .asg 6, OUTPUT_MA_E                                   ; P8_45 gpio2[6] -> bit6 output_MA_E no hace f
      90  .asg 7, OUTPUT_MA_D                                   ; P8_46 gpio2[7] -> bit7 output_MA_D config-pi
      91
      92  .asg 8, OUTPUT_MB_E                                   ; P8_43 gpio2[8] -> bit8 output_MB_E config-pi
      93  .asg 9, OUTPUT_MB_D                                   ; P8_44 gpio2[9] -> bit9 output_MB_D config-pi
      94
      95  .asg 10, OUTPUT_MC_E                                  ; P8_41 gpio2[10]-> bit10 output_MC_E config-p
      96  .asg 11, OUTPUT_MC_D                                  ; P8_42 gpio2[11]-> bit11 output_MC_D config-p
      97
      98  .asg 12, OUTPUT_MD_E                                  ; P8_39 gpio2[12]-> bit12 output_MD_E config-p
      99  .asg 13, OUTPUT_MD_D                                  ; P8_40 gpio2[13]-> bit13 output_MD_D config-p
     100
     101  ; Step period (medio ciclo de la senial)
     102  .asg (1<<14), OUTPUT_MA_S                             ; P8_37 gpio2[14] output_MA_S no hace falta ha
     103  .asg (1<<15), OUTPUT_MB_S                             ; P8_38 gpio2[15] output_MB_S
     104  .asg (1<<16), OUTPUT_MC_S                             ; P8_36 gpio2[16] output_MC_S
     105  .asg (1<<17), OUTPUT_MD_S                             ; P8_34 gpio2[17] output_MD_S
