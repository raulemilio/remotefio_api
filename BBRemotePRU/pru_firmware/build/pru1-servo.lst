      11
      12; pru1Control
      13  .asg 0x22000, PRU0_CTRL
      14  .asg 0x24000, PRU1_CTRL                               ; page 19
      15  .asg 0x28, CTPPR0                                     ; page 75
      16
      17; memory
      18  .asg 0x00000000, RAM0_ADDR                            ; local addr ram0. In linux space addr is 0x4a
      19  .asg 0x00002000, RAM1_ADDR                            ; local addr ram1. In linux space addr is 0x4a
      20  .asg 0x00010000, SHARED_ADDR                          ; local addr shared. In linux space addr is 0x
      21
      22  .asg 0x00, SHD_0                                      ; shared[0] flags linux
      23  .asg 0x04, SHD_1                                      ; shared[1] gpio_read get
      24  .asg 0x08, SHD_2                                      ; shared[2] gpio_read send rising detect
      25  .asg 0x0C, SHD_3                                      ; shared[3] gpio_write get-set
      26  .asg 0x10, SHD_4                                      ; shared[4] motor get-set
      27  .asg 0x14, SHD_5                                      ; shared[5] motor_A STEP_PERIOD_A
      28  .asg 0x18, SHD_6                                      ; shared[6] motor_B STEP_PERIOD_B
      29  .asg 0x1C, SHD_7                                      ; shared[7] motor_C STEP_PERIOD_C
      30  .asg 0x20, SHD_8                                      ; shared[8] motor_D STEP_PERIOD_D
      31  .asg 0x24, SHD_9                                      ; shared[9] send enable-dir MA y MB rising det
      32  .asg 0x0a, SHARED_MEM_SIZE                            ; 10 en decimal
      33  .asg 0x04, OFFSET_MEM                                 ;
      34
      35; gpio bank
      36  .asg 0x44e07000, GPIO0                                ; GPIO Bank 0, See the AM335x TRM
      37  .asg 0x481ac000, GPIO2                                ; GPIO Bank 2
      38
      39  .asg 0x190, GPIO_CLRDATAOUT                           ; for clearing the GPIO registers
      40  .asg 0x194, GPIO_SETDATAOUT                           ; for setting the GPIO registers
      41  .asg 0x13C, GPIO_DATAOUT                              ; for read-write the GPIO registers
      42  .asg 0x138, GPIO_DATAIN                               ; for reading the GPIO registers
      43  .asg 0x38,  GPIO_IRQSTATUS_SET_1                      ; habilita las interrupciones por set
      44  .asg 0x148, GPIO_RISINGDETECT                         ; habilita las interrupciones por flanco asc
      45  .asg 0x30,  GPIO_IRQSTATUS_1                          ; get-set irq
      46  .asg 0x150, GPIO_DEBOUNCENABLE                        ; antirebote enable register
      47  .asg 0x54,  GPIO_DEBOUNCINGTIME                       ; tiempo en us antirebote register
      48  .asg 0xD,  DEBOUNCETIME                               ; tiempo en us value
      49  .asg 0xF00, GPIO0_LEVELDETECT_MASK                    ; bits 8-11 bit22
      50  .asg 0x08800000, GPIO0_RISINGDETECT_MASK              ; bit23 y bit 27
      51  .asg 0x01, GPIO2_RISINGDETECT_MASK                    ; pin P8_18 GPIO2_1 flanco asc detect para fun
      52
      53  .asg 0x130, GPIO_CTRL                                 ; enable GPIO port
      54  .asg 0x00,  GPIO_CTRL_ENABLE                          ;
      55  .asg 0x134, GPIO_OE                                   ; set GPIO input - output
