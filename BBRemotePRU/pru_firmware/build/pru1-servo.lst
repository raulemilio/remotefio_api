      59; gpio_read
      60  ; Pins
      61  ; P8_35 gpio0[8] -> bit8 input_0  no hace falta hacer: config-pin P8_35 gpio_pd
      62  ; P8_33 gpio0[9] -> bit9 input_1  no hace falta hacer: config-pin P8_33 gpio_pd
      63  ; P8_31 gpio0[10]-> bit10 input_2 no hace falta hacer: config-pin P8_31 gpio_pd
      64  ; P8_32 gpio0[11]-> bit11 input_3 no hace falta hacer: config-pin P8_32 gpio_pd
      65
      66  ; MOTOR_A hardware pins
      67  .asg 22, INPUT_MA_DISABLE                             ; P8_19 gpio0[22]-> bit22 input_MA_E set disab
      68  .asg 23, INPUT_MA_TD                                  ; P8_13 gpio0[23]-> bit23 input_MA_D set toogl
      69  ; MOTOR_B hardware pins
      70  .asg 26, INPUT_MB_DISABLE                             ; P8_14 gpio0[26]-> bit26 input_MB_E set disab
      71  .asg 27, INPUT_MB_TD                                  ; P8_17 gpio0[27]-> bit27 input_MB_D set toogl
      72  .asg 1, INPUT_GPIO_READ_ASC                           ; P8_18 gpio2[1]-> bit1 input gpio read send r
      73
      74; gpio_write
      75  .asg  (1<<22),  GPIO_OUT_BASE                         ;
      76  ; Pins
      77  ; P8_27 gpio2[22]-> bit22 output_0 no hace falta hacer: config-pin P8_27 gpio
      78  ; P8_29 gpio2[23]-> bit23 output_1 no hace falta hacer: config-pin P8_29 gpio
      79  ; P8_28 gpio2[24]-> bit24 output_2 no hace falta hacer: config-pin P8_28 gpio
      80  ; P8_30 gpio2[25]-> bit25 output_3 no hace falta hacer: config-pin P8_30 gpio
      81
      82; motor
      83  ; Enable-Direction
      84  .asg (1<<6), GPIO_MOTOR_ENA_BASE                      ;
      85  .asg (1<<7), GPIO_MOTOR_DIR_BASE                      ;
      86
      87  ; Pins
      88  .asg 6, OUTPUT_MA_E                                   ; P8_45 gpio2[6] -> bit6 output_MA_E no hace f
      89  .asg 7, OUTPUT_MA_D                                   ; P8_46 gpio2[7] -> bit7 output_MA_D config-pi
      90
      91  .asg 8, OUTPUT_MB_E                                   ; P8_43 gpio2[8] -> bit8 output_MB_E config-pi
      92  .asg 9, OUTPUT_MB_D                                   ; P8_44 gpio2[9] -> bit9 output_MB_D config-pi
      93
      94  .asg 10, OUTPUT_MC_E                                  ; P8_41 gpio2[10]-> bit10 output_MC_E config-p
      95  .asg 11, OUTPUT_MC_D                                  ; P8_42 gpio2[11]-> bit11 output_MC_D config-p
      96
      97  .asg 12, OUTPUT_MD_E                                  ; P8_39 gpio2[12]-> bit12 output_MD_E config-p
      98  .asg 13, OUTPUT_MD_D                                  ; P8_40 gpio2[13]-> bit13 output_MD_D config-p
      99
     100  ; Step period (medio ciclo de la senial)
     101  .asg (1<<14), OUTPUT_MA_S                             ; P8_37 gpio2[14] output_MA_S no hace falta ha
     102  .asg (1<<15), OUTPUT_MB_S                             ; P8_38 gpio2[15] output_MB_S
     103  .asg (1<<16), OUTPUT_MC_S                             ; P8_36 gpio2[16] output_MC_S
     104  .asg (1<<17), OUTPUT_MD_S                             ; P8_34 gpio2[17] output_MD_S
     105
